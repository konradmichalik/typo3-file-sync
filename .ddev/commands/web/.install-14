#!/bin/bash

. .ddev/.setup/scripts/utils.sh

pre_setup 14

_progress " ├─ Install test sitepackage"
  composer config repositories.fixtures path "packages/$EXTENSION_KEY/Tests/Acceptance/Fixtures/packages/*" --working-dir "$BASE_PATH"
  composer req test/sitepackage:'*@dev' \
          --no-progress -n -d $BASE_PATH
_done

post_setup
