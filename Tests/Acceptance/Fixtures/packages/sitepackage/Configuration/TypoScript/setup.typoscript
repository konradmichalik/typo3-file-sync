page = PAGE
page {
    typeNum = 0

    10 = FLUIDTEMPLATE
    10 {
        templateName = Default
        templateRootPaths.10 = EXT:sitepackage/Resources/Private/Templates/Page/
        layoutRootPaths.10 = EXT:sitepackage/Resources/Private/Layouts/Page/
        partialRootPaths.10 = EXT:sitepackage/Resources/Private/Partials/

        dataProcessing {
            10 = TYPO3\CMS\Frontend\DataProcessing\DatabaseQueryProcessor
            10 {
                table = tt_content
                orderBy = sorting
                where.dataWrap = colPos=0 AND pid={field:uid}
                as = content
            }
        }

        variables {
            content < styles.content.get
        }
    }
}
